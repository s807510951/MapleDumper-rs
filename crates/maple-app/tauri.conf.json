{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MapleDumper",
  "version": "0.2.0",
  "identifier": "com.tajuc.mapledumper",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MapleDumper",
        "width": 1320,
        "height": 860,
        "minWidth": 940,
        "minHeight": 640,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; worker-src 'self'; connect-src 'self'"
    }
  }
}
